[Approach -- Using HashMap to track the Frequency of Each element and find whose Frequency is 1]
[Time Complexity -- O(n)]
----------------------------------------------------------------------------------------------------------------------------------------------------------------------

import java.util.HashMap;
class Solution {
    public int singleNumber(int[] nums) {
        HashMap<Integer, Integer> map = new HashMap<>();
        for(int ele : nums){
            map.put(ele,map.getOrDefault(ele,0)+1);
        }
        for(int key : map.keySet()){
            int freq = map.get(key);
            if(freq == 1){
                return key;
            }
            else{
                continue;
            }
        }
        return -1;
    }
}
