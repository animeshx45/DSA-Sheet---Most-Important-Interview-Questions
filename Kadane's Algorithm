import java.util.ArrayList;
class Solution {
    public int maxSubArray(int[] nums) {
        int n = nums.length;
        int sum = Integer.MIN_VALUE;
        for (int i = 0; i < n; i++){
            int count = 0;
            for (int j = i; j <n; j++){
                count += nums[j];
                if(count>sum){
                    sum = count;
                }
            }
        }
        return sum;
    }
}
