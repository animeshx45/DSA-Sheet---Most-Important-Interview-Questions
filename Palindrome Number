class Solution {
    public boolean isPalindrome(int x) {
        String str = Integer.toString(x);
        StringBuilder sb = new StringBuilder(str);
        int i = 0; int j = sb.length()-1;
        while(i<=j){
            if(sb.charAt(i)!=sb.charAt(j)){
                return false;
            }
             i++; j--;
        }
        return true;
    }
}
