import java.util.HashMap;
class Solution {
    public boolean searchMatrix(int[][] matrix, int target) {
        HashMap<Integer,Integer> map = new HashMap<>();
        int n = matrix.length;
        for(int [] ele : matrix){
            for(int ele1 : ele){
                map.put(ele1,map.getOrDefault(ele1,0)+1);
            }
        }
        int freq = 0;
        for(int key : map.keySet()){
            if(key == target){
                 freq = map.get(key);
            }
        }
        if (freq>0){
            return true;
        }
        return false;
    }
}
